# Retrieval Playground - Environment Variables
# Copy this file to .env and fill in your actual API keys

# Google Gemini API Key (Required - Primary Option)
# Get your free API key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (Optional - Alternative to Gemini)
# Get your API key from: https://platform.openai.com/api-keys
# Uncomment the line below if using OpenAI instead of Gemini
# OPENAI_API_KEY=your_openai_api_key_here

# Qdrant Vector Database (Required for workshop)
# Option A: Use instructor's shared credentials (provided during workshop)
# Option B: Create free account at https://cloud.qdrant.io/
QDRANT_URL=your_qdrant_url_here
QDRANT_KEY=your_qdrant_key_here

# Optional: Add any other configuration here
